{
  "name": "hermes-guardian-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Source for the Hermes Guardian dashboard plugin bundle (dist/index.js + dist/style.css).",
  "type": "module",
  "scripts": {
    "build:js": "bun build src/index.tsx --outfile dist/index.js --format=iife --target=browser --minify",
    "build:css": "bun build src/styles/index.css --outfile dist/style.css --minify",
    "build": "bun run build:js && bun run build:css",
    "dev": "bun build src/index.tsx --outfile dist/index.js --format=iife --target=browser --watch",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "typescript": "^5.6.0"
  }
}
